<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TabEditorViewModel"
             x:Class="JamSeshun.Views.TabEditorView"
             Background="#111827">

  <Design.DataContext>
    <vm:TabEditorViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1e293b" />
      <Setter Property="Foreground" Value="#e2e8f0" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="CaretBrush" Value="#7fc0f4" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#7fc0f4" />
    </Style>
    <Style Selector="Button.save-btn">
      <Setter Property="Background" Value="#1e3a5f" />
      <Setter Property="Foreground" Value="#7fc0f4" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="Padding" Value="20,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.save-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4a7f" />
    </Style>
    <Style Selector="Button.save-btn:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#0f172a" />
      <Setter Property="Foreground" Value="#334155" />
    </Style>
    <Style Selector="Button.clear-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- ── Field header ───────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="12,12,12,10">
      <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

        <!-- Artist -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="ARTIST"
                   FontSize="10" FontWeight="SemiBold" Foreground="#64748b"
                   Margin="2,0,0,4" />
        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                 PlaceholderText="Artist name"
                 Text="{Binding Artist}"
                 Margin="0,0,0,8" />

        <!-- Song -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="SONG"
                   FontSize="10" FontWeight="SemiBold" Foreground="#64748b"
                   Margin="2,0,0,4" VerticalAlignment="Bottom" />
        <TextBlock Grid.Row="2" Grid.Column="1"
                   Text="TUNING  ·  CAPO"
                   FontSize="10" FontWeight="SemiBold" Foreground="#64748b"
                   Margin="8,0,0,4" VerticalAlignment="Bottom" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="12,0,12,12">
      <Grid ColumnDefinitions="*,80,50">
        <TextBox Grid.Column="0"
                 PlaceholderText="Song name"
                 Text="{Binding Song}"
                 Margin="0,0,8,0" />
        <TextBox Grid.Column="1"
                 PlaceholderText="e.g. EADGBE"
                 Text="{Binding Tuning}"
                 Margin="0,0,8,0" />
        <NumericUpDown Grid.Column="2"
                       Minimum="0" Maximum="12"
                       Value="{Binding Capo}"
                       FormatString="0"
                       Background="#1e293b"
                       Foreground="#e2e8f0"
                       BorderBrush="#334155" />
      </Grid>
    </Border>

    <!-- ── Import progress ───────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Background="#0a0f1e"
            Padding="12,8"
            IsVisible="{Binding IsImporting}">
      <StackPanel Spacing="4">
        <ProgressBar Minimum="0"
                     Maximum="{Binding ImportTotal}"
                     Value="{Binding ImportCurrent}"
                     Foreground="#7fc0f4"
                     Background="#1e293b"
                     Height="4" />
        <TextBlock Text="{Binding ImportProgressText}"
                   Foreground="#64748b"
                   FontSize="11"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- ── Bottom bar ─────────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom" Background="#0f172a" Padding="12,10">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Text="{Binding SavedMessage}"
                   Foreground="#4ade80"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   IsVisible="{Binding HasSavedMessage}" />
        <Button Grid.Column="1"
                Classes="clear-btn"
                x:Name="ImportButton"
                IsEnabled="{Binding CanInteract}"
                Content="Import…"
                Margin="0,0,8,0" />
        <Button Grid.Column="2"
                Classes="clear-btn"
                Command="{Binding ClearCommand}"
                IsEnabled="{Binding CanInteract}"
                Content="New"
                Margin="0,0,8,0" />
        <Button Grid.Column="3"
                Classes="save-btn"
                Command="{Binding SaveCommand}"
                Content="Save" />
      </Grid>
    </Border>

    <!-- ── Tab content editor ─────────────────────────────── -->
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <TextBox AcceptsReturn="True"
               AcceptsTab="True"
               Text="{Binding Content}"
               FontFamily="Consolas,Courier New,monospace"
               FontSize="13"
               Foreground="#e2e8f0"
               Background="#111827"
               BorderThickness="0"
               Padding="14,12"
               TextWrapping="NoWrap"
               PlaceholderText="Paste or type your tab here..." />
    </ScrollViewer>

  </DockPanel>
</UserControl>
