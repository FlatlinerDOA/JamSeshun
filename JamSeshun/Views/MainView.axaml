<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             xmlns:views="using:JamSeshun.Views"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="JamSeshun.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <TabbedPage>
    <ContentPage Header="Tuner">
      <views:TunerView DataContext="{Binding TunerVM}" />
    </ContentPage>
    <NavigationPage Header="Songs">
      <ContentPage NavigationPage.HasNavigationBar="False">
        <views:TabListView DataContext="{Binding TabListVM}" />
      </ContentPage>
    </NavigationPage>
    <!-- <ContentPage Header="Performance"> -->
    <!--   <views:PerformanceView DataContext="{Binding PerformanceVM}" /> -->
    <!-- </ContentPage> -->
  </TabbedPage>
</UserControl>
