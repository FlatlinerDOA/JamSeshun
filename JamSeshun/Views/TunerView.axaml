<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             xmlns:views="using:JamSeshun.Views"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TunerViewModel"
             x:Class="JamSeshun.Views.TunerView"
             Background="#111827">

  <Design.DataContext>
    <vm:TunerViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Button.start-btn">
      <Setter Property="Background" Value="#1e3a5f" />
      <Setter Property="Foreground" Value="#7fc0f4" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="Padding" Value="40,14" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.start-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4a7f" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#1e293b" />
      <Setter Property="Foreground" Value="#e2e8f0" />
      <Setter Property="BorderBrush" Value="#334155" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- ── Input device picker ────────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="12,10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="INPUT DEVICE"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#64748b"
                   Margin="2,0,0,4" />
        <ComboBox ItemsSource="{Binding Devices}"
                  SelectedItem="{Binding SelectedDevice}"
                  HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </DockPanel>
    </Border>

    <!-- ── Note display ───────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Padding="0,24,0,0">
      <StackPanel HorizontalAlignment="Center" Spacing="4">
        <TextBlock Text="{Binding NoteDisplay}"
                   FontSize="80" FontWeight="Bold" Foreground="White"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding FrequencyDisplay}"
                   FontSize="18" Foreground="#94a3b8"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding ErrorDisplay}"
                   FontSize="13" Foreground="#64748b"
                   HorizontalAlignment="Center"
                   MinHeight="18" />
      </StackPanel>
    </Border>

    <!-- ── Start/Stop button + live diagnostics ───────────── -->
    <Border DockPanel.Dock="Bottom" Padding="16,16,16,24">
      <StackPanel HorizontalAlignment="Center" Spacing="10">
        <!-- Live input level meter: confirms the selected device is receiving audio -->
        <ProgressBar Width="220" Height="4"
                     Minimum="0" Maximum="0.2"
                     Value="{Binding SignalLevel}"
                     Foreground="#4ade80" Background="#1e293b"
                     IsVisible="{Binding IsRunning}" />
        <TextBlock Text="{Binding DiagnosticsDisplay}"
                   FontFamily="Consolas,monospace" FontSize="11"
                   Foreground="#475569"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding IsRunning}" />
        <Button Classes="start-btn"
                Command="{Binding StartCommand}"
                Content="{Binding StartButtonText}"
                HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- ── Gauge (fills remaining space) ─────────────────── -->
    <views:TunerNeedle Angle="{Binding CurrentErrorInDegrees}"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />

  </DockPanel>
</UserControl>
