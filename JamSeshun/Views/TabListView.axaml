<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TabListViewModel"
             x:Class="JamSeshun.Views.TabListView"
             Background="#111827">

  <Design.DataContext>
    <vm:TabListViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1e293b" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#1e3a5f" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1e293b" />
      <Setter Property="Foreground" Value="#e2e8f0" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="CaretBrush" Value="#7fc0f4" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#7fc0f4" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="#1e3a5f" />
      <Setter Property="Foreground" Value="#7fc0f4" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="Padding" Value="14,8" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4a7f" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- ── Search bar ──────────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="12,10">
      <TextBox PlaceholderText="Search tabs..."
               Text="{Binding SearchQuery}" />
    </Border>

    <!-- ── Scrollable list area ──────────────────────────── -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- Results -->
        <StackPanel IsVisible="{Binding HasSearchResults}">
          <TextBlock Text="SEARCH RESULTS"
                     Margin="16,14,16,6"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#64748b" />
          <ListBox ItemsSource="{Binding SearchResults}"
                   SelectedItem="{Binding SelectedTabReference}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:TabReferenceViewModel">
                <Border Padding="16,10" BorderBrush="#1e293b" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding Song}"
                                 Foreground="#e2e8f0"
                                 FontWeight="SemiBold"
                                 FontSize="14" />
                      <TextBlock Text="{Binding Artist}"
                                 Foreground="#94a3b8"
                                 FontSize="13" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="›"
                               Foreground="#475569"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>

        <!-- My Tabs -->
        <StackPanel IsVisible="{Binding !HasSearchResults}">
          <TextBlock Text="MY TABS"
                     Margin="16,14,16,6"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#64748b" />
          <ListBox ItemsSource="{Binding AllTabs}"
                   SelectedItem="{Binding SelectedTabReference}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:TabReferenceViewModel">
                <Border Padding="16,12" BorderBrush="#1e293b" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding Song}"
                                 Foreground="#e2e8f0"
                                 FontWeight="SemiBold"
                                 FontSize="14" />
                      <TextBlock Text="{Binding Artist}"
                                 Foreground="#94a3b8"
                                 FontSize="13" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="›"
                               Foreground="#475569"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</UserControl>
