<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:behaviors="using:JamSeshun.Behaviors"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TabEditorViewModel"
             x:Class="JamSeshun.Views.TabEditorView"
             Background="#111827">

  <Design.DataContext>
    <vm:TabEditorViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1e293b" />
      <Setter Property="Foreground" Value="#e2e8f0" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="CaretBrush" Value="#7fc0f4" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#7fc0f4" />
    </Style>
    <Style Selector="Button.save-btn">
      <Setter Property="Background" Value="#1e3a5f" />
      <Setter Property="Foreground" Value="#7fc0f4" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="Padding" Value="20,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.save-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4a7f" />
    </Style>
    <Style Selector="Button.save-btn:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#0f172a" />
      <Setter Property="Foreground" Value="#334155" />
    </Style>
    <Style Selector="Button.clear-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- ── Header with back button ────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="0,8,16,8">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <Button Grid.Column="0"
                x:Name="BackButton"
                Background="Transparent"
                BorderThickness="0"
                Padding="10"
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <i:Icon Value="fa-solid fa-arrow-left" FontSize="15" Foreground="#7fc0f4" />
        </Button>
        <TextBlock Grid.Column="1"
                   Text="{Binding Title}"
                   FontSize="18" FontWeight="Bold" Foreground="White"
                   VerticalAlignment="Center" />
        <Button Grid.Column="2"
                Command="{Binding DeleteCommand}"
                IsVisible="{Binding CanDelete}"
                Background="Transparent"
                BorderThickness="0"
                Padding="10"
                Margin="4,0"
                VerticalAlignment="Center"
                ToolTip.Tip="Delete tab">
          <i:Icon Value="fa-solid fa-trash" FontSize="15" Foreground="#ef4444" />
        </Button>
        <Button Grid.Column="3"
                Classes="save-btn"
                Command="{Binding SaveCommand}"
                Content="Save"
                VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- ── Field rows ─────────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="12,8,12,4">
      <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="ARTIST"
                   FontSize="10" FontWeight="SemiBold" Foreground="#64748b"
                   Margin="2,0,0,4" />
        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                 PlaceholderText="Artist name"
                 Text="{Binding Artist}"
                 Margin="0,0,0,8" />
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="SONG"
                   FontSize="10" FontWeight="SemiBold" Foreground="#64748b"
                   Margin="2,0,0,4" VerticalAlignment="Bottom" />
        <TextBlock Grid.Row="2" Grid.Column="1"
                   Text="{Binding CapoLabel}"
                   FontSize="10" FontWeight="SemiBold" Foreground="#64748b"
                   Margin="8,0,0,4" VerticalAlignment="Bottom" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="12,0,12,12">
      <Grid ColumnDefinitions="*,90,60">
        <TextBox Grid.Column="0"
                 PlaceholderText="Song name"
                 Text="{Binding Song}"
                 Margin="0,0,8,0" />
        <TextBox Grid.Column="1"
                 PlaceholderText="EADGBE"
                 Text="{Binding Tuning}"
                 Margin="0,0,8,0" />
        <Grid Grid.Column="2" ColumnDefinitions="Auto,*,Auto">
          <Button Grid.Column="0"
                  Command="{Binding DecrementCapoCommand}"
                  Content="−"
                  Padding="10,6"
                  Background="#1e293b"
                  Foreground="#e2e8f0"
                  BorderBrush="#334155" />
          <TextBlock Grid.Column="1"
                     Text="{Binding Capo}"
                     Foreground="#e2e8f0"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
          <Button Grid.Column="2"
                  Command="{Binding IncrementCapoCommand}"
                  Content="+"
                  Padding="10,6"
                  Background="#1e293b"
                  Foreground="#e2e8f0"
                  BorderBrush="#334155" />
        </Grid>
      </Grid>
    </Border>

    <!-- ── Delete confirmation ───────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Background="#1a0a0a"
            BorderBrush="#ef4444"
            BorderThickness="0,1,0,0"
            Padding="12,10"
            IsVisible="{Binding IsConfirmingDelete}">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Text="Delete this tab?"
                   Foreground="#fca5a5"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Command="{Binding CancelDeleteCommand}"
                Content="Cancel"
                Background="Transparent"
                Foreground="#94a3b8"
                BorderThickness="0"
                Padding="14,8"
                Margin="0,0,8,0" />
        <Button Grid.Column="2"
                Command="{Binding ConfirmDeleteCommand}"
                Content="Delete"
                Background="#ef4444"
                Foreground="White"
                BorderThickness="0"
                Padding="14,8" />
      </Grid>
    </Border>

    <!-- ── Saved confirmation ─────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Background="#0f172a"
            Padding="12,8"
            IsVisible="{Binding HasSavedMessage}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="{Binding SavedMessage}"
                   Foreground="#4ade80"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <Button Classes="clear-btn"
                Command="{Binding ClearCommand}"
                Content="New tab"
                Padding="10,4" />
      </StackPanel>
    </Border>

    <!-- ── Tab content editor ─────────────────────────────── -->
    <TextBox AcceptsReturn="True"
             AcceptsTab="True"
             Text="{Binding Content}"
             FontFamily="avares://JamSeshun/Assets/Fonts#JetBrains Mono"
             FontSize="13"
             Foreground="#e2e8f0"
             Background="#111827"
             BorderThickness="0"
             Padding="14,12"
             TextWrapping="NoWrap"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             PlaceholderText="Paste or type your tab here..."
             behaviors:InputPaneAssist.AdjustForKeyboard="True" />

  </DockPanel>
</UserControl>
