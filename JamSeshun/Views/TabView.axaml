<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             xmlns:services="using:JamSeshun.Services"
             xmlns:views="using:JamSeshun.Views"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TabViewModel"
             x:Class="JamSeshun.Views.TabView"
             Background="#111827">

  <Design.DataContext>
    <vm:TabViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <!-- Chord pill button -->
    <Style Selector="Button.chord-pill">
      <Setter Property="Background" Value="#1e3a5f" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.chord-pill /template/ ContentPresenter">
      <Setter Property="Background" Value="#1e3a5f" />
    </Style>
    <Style Selector="Button.chord-pill:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4a7f" />
    </Style>
    <Style Selector="Button.chord-pill TextBlock">
      <Setter Property="Foreground" Value="#7fc0f4" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- ── Header ─────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="16,12,16,10">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding Song}"
                   FontSize="20" FontWeight="Bold" Foreground="White"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding Artist}"
                   FontSize="14" Foreground="#94a3b8"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding TuningDisplay}"
                   FontSize="12" Foreground="#7fc0f4"
                   IsVisible="{Binding HasTuning}"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- ── Chord strip ─────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Background="#0a0f1e"
            Padding="12,8"
            IsVisible="{Binding HasChords}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Chords}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="services:Chord">
              <Button Classes="chord-pill">
                <Button.Flyout>
                  <Flyout Placement="Bottom">
                    <Border Background="#1e293b"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,12">
                      <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#e2e8f0"
                                   HorizontalAlignment="Center" />
                        <views:ChordDiagramControl Frets="{Binding Frets}"
                                                   IsVisible="{Binding Frets, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <TextBlock Text="No diagram"
                                   FontSize="11" Foreground="#475569"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding Frets, Converter={x:Static ObjectConverters.IsNull}}" />
                      </StackPanel>
                    </Border>
                  </Flyout>
                </Button.Flyout>
                <TextBlock Text="{Binding Name}" />
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- ── Tab content ────────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Height="1" Background="#1e293b" />

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Lines}" Padding="16,14,16,24">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:TabLine">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding ForegroundBrush}"
                       FontFamily="Consolas,Courier New,monospace"
                       FontSize="13"
                       FontWeight="{Binding FontWeight}"
                       MinHeight="{Binding MinHeight}"
                       TextWrapping="NoWrap" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
