<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JamSeshun.ViewModels"
             xmlns:services="using:JamSeshun.Services"
             xmlns:views="using:JamSeshun.Views"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TabViewModel"
             x:Class="JamSeshun.Views.TabView"
             Background="#111827">

  <Design.DataContext>
    <vm:TabViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <!-- Chord pill button -->
    <Style Selector="Button.chord-pill">
      <Setter Property="Background" Value="#1e3a5f" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="Margin" Value="10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.chord-pill /template/ ContentPresenter">
      <Setter Property="Background" Value="#1e3a5f" />
    </Style>
    <Style Selector="Button.chord-pill:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4a7f" />
    </Style>
    <Style Selector="Button.chord-pill TextBlock">
      <Setter Property="Foreground" Value="#7fc0f4" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- ── Header (with embedded back + edit buttons) ────── -->
    <Border DockPanel.Dock="Top" Background="#0f172a" Padding="0,8,4,10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Button Grid.Column="0"
                x:Name="BackButton"
                Background="Transparent"
                BorderThickness="0"
                Padding="10"
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <i:Icon Value="fa-solid fa-arrow-left" FontSize="15" Foreground="#7fc0f4" />
        </Button>
        
        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
          <TextBlock Text="{Binding Song}"
                     FontSize="20" FontWeight="Bold" Foreground="White"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding Artist}"
                     FontSize="14" Foreground="#94a3b8"
                     TextTrimming="CharacterEllipsis" />
          <Button x:Name="TuneButton"
                  Background="Transparent" BorderThickness="0"
                  Padding="0" Margin="0,2,0,0"
                  Cursor="Hand"
                  IsVisible="{Binding HasParsableTuning}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="{Binding TuningDisplay}"
                         FontSize="12" Foreground="#7fc0f4" />
              <TextBlock Text="· Tune"
                         FontSize="11" Foreground="#4a7fc0" />
            </StackPanel>
          </Button>
          <!-- Capo-only or unrecognised tuning display -->
          <TextBlock Text="{Binding TuningDisplay}"
                     FontSize="12" Foreground="#7fc0f4"
                     IsVisible="{Binding HasTuningDisplayOnly}"
                     Margin="0,2,0,0" />
        </StackPanel>
        <Button Grid.Column="2"
                x:Name="EditButton"
                Background="Transparent"
                BorderThickness="0"
                Padding="10"
                Margin="10"
                VerticalAlignment="Center"
                ToolTip.Tip="Edit tab">
          <i:Icon Value="fa-solid fa-pen" FontSize="15" Foreground="#7fc0f4" />
        </Button>
      </Grid>
    </Border>

    <!-- ── Chord strip ─────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Background="#0a0f1e"
            Padding="12,8"
            IsVisible="{Binding HasChords}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Chords}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="services:Chord">
              <Button Classes="chord-pill">
                <Button.Flyout>
                  <Flyout Placement="Bottom">
                    <Border Background="#1e293b"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,12">
                      <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#e2e8f0"
                                   HorizontalAlignment="Center" />
                        <views:ChordDiagramControl Frets="{Binding Frets}"
                                                   IsVisible="{Binding Frets, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <TextBlock Text="No diagram"
                                   FontSize="11" Foreground="#475569"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding Frets, Converter={x:Static ObjectConverters.IsNull}}" />
                      </StackPanel>
                    </Border>
                  </Flyout>
                </Button.Flyout>
                <TextBlock Text="{Binding Name}" />
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- ── Tab content ────────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Height="1" Background="#1e293b" />

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Lines}" Padding="16,14,16,24">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:TabLine">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding ForegroundBrush}"
                       FontFamily="avares://JamSeshun/Assets/Fonts#JetBrains Mono"
                       FontSize="13"
                       FontWeight="{Binding FontWeight}"
                       MinHeight="{Binding MinHeight}"
                       TextWrapping="NoWrap" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
